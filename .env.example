# Conjure config — copy to `.env` and edit. NOTHING here is required for local use.
# Conjure reads this file at startup (no dotenv dependency).

# HTTP port (default 8091)
PORT=8091

# Model passed to `claude -p` (default claude-sonnet-5)
CONJURE_MODEL=claude-sonnet-5

# --- Auth gate: leave BOTH unset for open local access on localhost ---
# Set these only if you expose Conjure on a public URL. The server drives your
# Claude account, so public access without a passphrase = an open door.
# CONJURE_PASSPHRASE=some-three-word-phrase
# CONJURE_COOKIE_SECRET=   # random hex; `openssl rand -hex 32`

# Dev escape hatch: run without a passphrase even under NODE_ENV=production
# CONJURE_ALLOW_OPEN=1

# --- Tuning (defaults shown) ---
# CONJURE_MAX_CONCURRENT=2
# CONJURE_AUTH_RATE_MAX=5
# CONJURE_AUTH_RATE_WINDOW_MS=900000
# CONJURE_UPDATE_RATE_MAX=10
# CONJURE_UPDATE_RATE_WINDOW_MS=3600000

# --- Claude auth (alternative to `claude` CLI login) ---
# If you're not logged in via the CLI, provide a token from `claude setup-token`.
# Prefer exporting this in your shell rather than committing it here.
# CLAUDE_CODE_OAUTH_TOKEN=
