[Unit]
Description=Conjure — sketch-to-live-app
After=network.target

[Service]
User=vlad
WorkingDirectory=/home/vlad/conjure
EnvironmentFile=/home/vlad/jarvis/.env
Environment=PORT=8091
ExecStart=/usr/bin/node /home/vlad/conjure/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
